/**
 * audioMessages.js
 * ─────────────────────────────────────────────────────────────────
 * PURPOSE:
 *   Pure utility functions that convert raw YOLO detection objects
 *   into natural, human-readable sentences for a visually impaired user.
 *
 *   "Pure" means: no React, no hooks, no side effects, no imports from
 *   the rest of the app. Every function takes data in and returns data
 *   out. This makes the logic testable, predictable, and easy to change
 *   later without touching anything else.
 *
 * WHAT LIVES HERE:
 *   1. Direction/distance label converters
 *   2. Object grouper (handles "2 chairs" instead of "chair, chair")
 *   3. Per-mode message builders
 *   4. The single exported entry point: buildAudioMessage()
 *
 * WHAT DOES NOT LIVE HERE:
 *   - Any call to window.speechSynthesis (that's useDrishtiAudio.js)
 *   - Any React state or refs
 *   - Any knowledge of modes beyond what's passed in
 * ─────────────────────────────────────────────────────────────────
 */

 // ─── SECTION 1: HUMAN-READABLE LABELS ────────────────────────────
//
// YOLO gives us raw numbers: cx=320, cy=500, w=200, h=300.
// These functions convert those numbers into words the user can act on.
//
// WHY THESE THRESHOLDS?
//   A 640px-wide frame is divided into thirds:
//     0–160   = "far left"   (outer quarter)
//     160–256 = "left"       (inner left third)
//     256–384 = "ahead"      (center third — most critical zone)
//     384–512 = "right"      (inner right third)
//     512–640 = "far right"  (outer quarter)
//
//   For depth, bounding box SIZE is the best offline proxy for distance.
//   A box that is 450px wide in a 640px frame is essentially filling the
//   entire field of view — that object is very close. We use width OR
//   height (whichever is larger) because tall objects (people) and wide
//   objects (cars) both need to be caught.
 
/**
 * Converts the horizontal center-x of a detection into a direction word.
 * @param {number} cx - Center X in the 640px model space
 * @returns {string}
 */
 * Converts bounding box size into a distance word.
 * Larger box = physically closer to the camera.
 *
 * WHY width AND height?
 *   A standing person close-up will be tall but not wide.
 *   A car close-up will be wide but maybe not tall in frame.
 *   Taking Math.max() catches both cases.
 *
 * @param {number} w - Box width in 640px model space
 * @param {number} h - Box height in 640px model space
 * @returns {{ word: string, isUrgent: boolean }}
 * Converts a raw detection label into a user-friendly spoken name.
 * YOLO labels are dataset names like "cell phone", "potted plant" —
 * some of these sound unnatural when spoken aloud.
 *
 * WHY a map instead of just using the label directly?
 *   "dining table" sounds fine in text but awkward when a TTS voice
 *   reads it at speed. "table" is cleaner. We only override the ones
 *   that matter; everything else falls through to its original label.
 *
 * @param {string} label
 * @returns {string}

 export function getFriendlyLabel(label) {
  const overrides = {
    "cell phone":    "phone",
    "potted plant":  "plant",
    "dining table":  "table",
    "tv":            "television",
    "traffic light": "traffic light",
    "stop sign":     "stop sign",
    "fire hydrant":  "fire hydrant",
    "wine glass":    "glass",
    "sports ball":   "ball",
    "hair drier":    "hair dryer",
  };
  return overrides[label] ?? label;
}

// ─── SECTION 2: OBJECT GROUPER ───────────────────────────────────
//
// PROBLEM this solves:
//   If the AI detects 3 chairs, the naive approach produces:
//     "Chair to your left. Chair ahead. Chair to your right."
//   This is repetitive and confusing — which chair do I avoid?
//
// SOLUTION:
//   Group detections by their friendly label, then build one sentence
//   per unique object type that mentions ALL instances of that type.
//   Result: "Three chairs: one to your left, one ahead, one to your right."
//
// HOW GROUPING WORKS:
//   1. We receive a sorted array of detection objects (already priority-sorted
//      by useDrishtiAI before they reach us).
//   2. We reduce() the array into a Map keyed by friendly label.
//   3. Each entry stores an array of { direction, distance, isUrgent }.
//   4. Later, the message builder reads from this map.
//
// @param {Array} detections - Array of detection objects from useDrishtiAI
// @returns {Map<string, Array>} - label → array of instance descriptors
 

 // ─── SECTION 3: SENTENCE BUILDERS PER MODE ───────────────────────
//
// Different modes need different communication styles:
//
//   NORMAL    → Full descriptive sentences. "There is a person nearby to your left."
//   PATHFINDER → Terse, urgent. "Stop — person ahead."
//   EMERGENCY  → Loud, priority-first. "DANGER! Car very close, directly ahead."
//   HOME       → Calm, helpful. "Your phone is on the table to your right."
//   SHOPPING   → Item-centric. "Bottle to your left. Cup ahead."
//   SOCIAL     → People-first. "Two people nearby: one to your left, one ahead."
//   COUNT      → Inventory. "I can see: 2 people, 3 chairs, 1 bottle."
//   SILENT     → No audio (handled upstream, but return empty here too).
//
// WHY SEPARATE BUILDERS?
//   One giant function with if/else for every mode gets unreadable fast.
//   Each builder is a small, focused function you can tweak independently.
//   When you add a new mode, you add one new function — nothing else changes.

/**
 * Builds a single group sentence like:
 *   "Person to your left"         (1 instance)
 *   "Two chairs: one ahead, one to your right"   (2 instances)
 *   "Three cars: ahead, to your left, far to your right"  (3+)
 *
 * This is the core reusable building block that all mode builders call.
 *
 * @param {string} label
 * @param {Array}  instances  - array of { direction, distWord, isUrgent }
 * @param {boolean} includeDistance - whether to include "nearby", "far", etc.
 * @returns {string}
 */

 // ─── SECTION 4: MAIN ENTRY POINT ─────────────────────────────────
//
// This is the ONLY function that other files need to import.
// It accepts the detections array and current mode string,
// and returns a ready-to-speak string.
//
// WHY one entry point?
//   Callers don't need to know which builder to use. They just call
//   buildAudioMessage(detections, mode, isPathSafe) and get a string back.
//   If you add a new mode builder, you add one case here — callers are untouched.
 
/**
 * Converts an array of detections into a natural language sentence
 * appropriate for the given mode.
 *
 * @param {Array}   detections  - Sorted detection objects from useDrishtiAI
 * @param {string}  mode        - Current mode key e.g. "NORMAL", "PATHFINDER"
 * @param {boolean} isPathSafe  - Used by PATHFINDER mode
 * @returns {string}            - Ready-to-speak sentence, or "" if silent
 */
 // ─── SECTION 5: COOLDOWN HELPER ──────────────────────────────────
//
// PROBLEM: If inference runs at 15fps, buildAudioMessage() could be
// called 15 times per second. We obviously can't speak 15 times/second.
//
// SOLUTION: A cooldown map per mode. Each mode has a different "patience":
//   EMERGENCY  → speak every 500ms  (fast! danger!)
//   PATHFINDER → speak every 1500ms (frequent navigation updates)
//   NORMAL     → speak every 3000ms (calm awareness)
//   HOME       → speak every 3500ms (slow, familiar environment)
//   SHOPPING   → speak every 2500ms
//   SOCIAL     → speak every 4000ms (people don't change position quickly)
//   COUNT      → speak every 6000ms (inventory, set-and-forget)
//
// HOW TO USE:
//   Track the last spoken time in useDrishtiAudio.js using a ref:
//     const lastSpokenRef = useRef(0);
//   Then call: shouldSpeak(mode, lastSpokenRef.current)
//   If true → speak and update lastSpokenRef.current = Date.now()
 
 /**
 * Returns true if enough time has passed since the last announcement.
 * @param {string} mode
 * @param {number} lastSpokenTimestamp - Date.now() value of last speech
 * @returns {boolean}
 */
export function shouldSpeak(mode, lastSpokenTimestamp) 

// ─── SECTION 6: URGENCY DETECTOR ─────────────────────────────────
//
// Some situations need to INTERRUPT whatever is currently being spoken.
// For example: a car suddenly appears very close while the system is
// mid-sentence describing a chair in the distance.
//
// INTERRUPT RULES:
//   - Any object with distWord === "very close" triggers interrupt
//   - PATHFINDER path-blocked state always interrupts
//   - EMERGENCY mode always interrupts
//
// The speak() function in useDrishtiAudio.js has an `interrupt` parameter.
// This helper decides when to set it to true.
 
/**
 * Returns true if the current detections warrant interrupting ongoing speech.
 * @param {Array}   detections
 * @param {string}  mode
 * @param {boolean} isPathSafe
 * @returns {boolean}
 */